{
  "name": "@medcrm/backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "nest build api-gateway && nest build auth-service && nest build scheduling-service && nest build worker",
    "build:api-gateway": "nest build api-gateway",
    "build:auth-service": "nest build auth-service",
    "build:scheduling-service": "nest build scheduling-service",
    "build:worker": "nest build worker",
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:auth": "nest start auth-service --watch",
    "start:dev:scheduling": "nest start scheduling-service --watch",
    "start:dev:worker": "nest start worker --watch",
    "start:prod:api-gateway": "node dist/apps/api-gateway/src/main.js",
    "start:prod:auth-service": "node dist/apps/auth-service/src/main.js",
    "start:prod:scheduling-service": "node dist/apps/scheduling-service/src/main.js",
    "start:prod:worker": "node dist/apps/worker/src/main.js",
    "test:gateway": "tsx --test apps/api-gateway/src/*.spec.ts",
    "test:e2e": "for f in apps/auth-service/src/test/*.e2e-spec.ts; do TS_NODE_PROJECT=tsconfig.json node -r ts-node/register -r tsconfig-paths/register --test \"$f\" || exit 1; done",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate && prisma generate --schema=apps/scheduling-service/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy && prisma migrate deploy --schema=apps/scheduling-service/prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev && prisma migrate dev --schema=apps/scheduling-service/prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seeds/seed.ts",
    "audit:verify": "tsx prisma/scripts/verify-audit-chain.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.3",
    "@prisma/client": "^6.8.2",
    "@simplewebauthn/server": "^13.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.53.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^3.6.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.6.1",
    "jose": "^6.2.3",
    "nats": "^2.28.2",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@simplewebauthn/types": "^12.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.8.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seeds/seed.ts"
  }
}
