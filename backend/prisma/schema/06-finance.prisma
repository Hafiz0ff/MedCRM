model Invoice {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  appointmentId  String?   @map("appointment_id") @db.Uuid
  invoiceNumber  String    @map("invoice_number") @db.VarChar(120)
  status         String    @db.VarChar(40)
  subtotalAmount Decimal   @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount Decimal   @default(0.0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal   @default(0.0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal   @default(0.0) @map("paid_amount") @db.Decimal(12, 2)
  dueAmount      Decimal   @map("due_amount") @db.Decimal(12, 2)
  currency       String    @default("TJS") @db.VarChar(10)
  invoiceDate    DateTime  @default(now()) @map("invoice_date") @db.Timestamptz(6)
  dueDate        DateTime? @map("due_date") @db.Timestamptz(6)
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient             Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  creator             User                 @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  items               InvoiceItem[]
  payments            Payment[]
  refunds             Refund[]
  walletTransactions  WalletTransaction[]
  patientDebts        PatientDebt[]
  gatewayTransactions GatewayTransaction[]
  payrollCalculations PayrollCalculation[]

  @@unique([tenantId, invoiceNumber])
  @@map("invoices")
  @@schema("finance")
}

model InvoiceItem {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  invoiceId           String   @map("invoice_id") @db.Uuid
  serviceId           String   @map("service_id") @db.Uuid
  performerEmployeeId String?  @map("performer_employee_id") @db.Uuid
  quantity            Int      @default(1)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount      Decimal  @default(0.0) @map("discount_amount") @db.Decimal(12, 2)
  materialCost        Decimal  @default(0.0) @map("material_cost") @db.Decimal(12, 2)
  taxAmount           Decimal  @default(0.0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount         Decimal  @map("total_amount") @db.Decimal(12, 2)
  payrollIncluded     Boolean  @default(false) @map("payroll_included")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service             Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  performer           Employee?            @relation(fields: [performerEmployeeId], references: [id], onDelete: SetNull)
  allocations         PaymentAllocation[]
  payrollCalculations PayrollCalculation[]

  @@map("invoice_items")
  @@schema("finance")
}

model Payment {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  branchId              String   @map("branch_id") @db.Uuid
  invoiceId             String   @map("invoice_id") @db.Uuid
  patientId             String   @map("patient_id") @db.Uuid
  paymentMethod         String   @map("payment_method") @db.VarChar(40) // CASH, CARD, QR, BANK_TRANSFER, WALLET, etc.
  paymentProvider       String?  @map("payment_provider") @db.VarChar(80)
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("TJS") @db.VarChar(10)
  exchangeRate          Decimal  @default(1.0) @map("exchange_rate") @db.Decimal(10, 4)
  externalTransactionId String?  @map("external_transaction_id") @db.VarChar(255)
  cashierUserId         String   @map("cashier_user_id") @db.Uuid
  status                String   @default("COMPLETED") @db.VarChar(40) // PENDING, COMPLETED, FAILED, REFUNDED
  paidAt                DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice            Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patient            Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  cashier            User                @relation(fields: [cashierUserId], references: [id], onDelete: Cascade)
  allocations        PaymentAllocation[]
  refunds            Refund[]
  walletTransactions WalletTransaction[]

  @@map("payments")
  @@schema("finance")
}

model PaymentAllocation {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @map("tenant_id") @db.Uuid
  paymentId       String  @map("payment_id") @db.Uuid
  invoiceItemId   String  @map("invoice_item_id") @db.Uuid
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(12, 2)

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment     Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceItem InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)

  @@map("payment_allocations")
  @@schema("finance")
}

model Refund {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  paymentId    String   @map("payment_id") @db.Uuid
  refundAmount Decimal  @map("refund_amount") @db.Decimal(12, 2)
  refundMethod String   @map("refund_method") @db.VarChar(40)
  reason       String?  @db.VarChar(255)
  approvedBy   String?  @map("approved_by") @db.Uuid
  refundedBy   String   @map("refunded_by") @db.Uuid
  refundStatus String   @default("COMPLETED") @map("refund_status") @db.VarChar(40) // REQUESTED, APPROVED, REJECTED, COMPLETED
  refundedAt   DateTime @default(now()) @map("refunded_at") @db.Timestamptz(6)

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice            Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment            Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  approver           User?               @relation("RefundsApproved", fields: [approvedBy], references: [id], onDelete: SetNull)
  refunder           User                @relation("RefundsPerformed", fields: [refundedBy], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@map("refunds")
  @@schema("finance")
}

model PaymentGateway {
  id                String  @id @default(uuid()) @db.Uuid
  tenantId          String  @map("tenant_id") @db.Uuid
  code              String  @db.VarChar(80)
  name              String  @db.VarChar(255)
  gatewayType       String  @map("gateway_type") @db.VarChar(60)
  configurationJson Json    @map("configuration_json")
  isActive          Boolean @default(true) @map("is_active")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions GatewayTransaction[]

  @@unique([tenantId, code])
  @@map("payment_gateways")
  @@schema("finance")
}

model GatewayTransaction {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  gatewayId             String   @map("gateway_id") @db.Uuid
  invoiceId             String   @map("invoice_id") @db.Uuid
  externalTransactionId String?  @map("external_transaction_id") @db.VarChar(255)
  requestPayload        Json     @map("request_payload")
  responsePayload       Json     @map("response_payload")
  transactionStatus     String   @map("transaction_status") @db.VarChar(40)
  processedAt           DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  invoice Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("gateway_transactions")
  @@schema("finance")
}

model PatientWallet {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  patientId  String   @map("patient_id") @db.Uuid
  walletType String   @map("wallet_type") @db.VarChar(40) // DEPOSIT, BONUS, CREDIT
  balance    Decimal  @default(0.0) @db.Decimal(12, 2)
  currency   String   @default("TJS") @db.VarChar(10)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@unique([patientId, walletType])
  @@map("patient_wallets")
  @@schema("finance")
}

model WalletTransaction {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  walletId         String?  @map("wallet_id") @db.Uuid
  familyWalletId   String?  @map("family_wallet_id") @db.Uuid
  transactionType  String   @map("transaction_type") @db.VarChar(60) // DEPOSIT_TOPUP, PAYMENT, REFUND, BONUS_ACCRUAL, etc.
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("TJS") @db.VarChar(10)
  relatedInvoiceId String?  @map("related_invoice_id") @db.Uuid
  relatedPaymentId String?  @map("related_payment_id") @db.Uuid
  relatedRefundId  String?  @map("related_refund_id") @db.Uuid
  performedBy      String   @map("performed_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wallet        PatientWallet? @relation(fields: [walletId], references: [id], onDelete: Cascade)
  familyWallet  FamilyWallet?  @relation(fields: [familyWalletId], references: [id], onDelete: Cascade)
  invoice       Invoice?       @relation(fields: [relatedInvoiceId], references: [id], onDelete: SetNull)
  payment       Payment?       @relation(fields: [relatedPaymentId], references: [id], onDelete: SetNull)
  refund        Refund?        @relation(fields: [relatedRefundId], references: [id], onDelete: SetNull)
  performerUser User           @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
  @@schema("finance")
}

model FamilyWallet {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  familyGroupId String  @map("family_group_id") @db.Uuid
  walletType    String  @map("wallet_type") @db.VarChar(40) // DEPOSIT, BONUS
  balance       Decimal @default(0.0) @db.Decimal(12, 2)
  currency      String  @default("TJS") @db.VarChar(10)
  isShared      Boolean @default(true) @map("is_shared")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  familyGroup  FamilyGroup         @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@unique([familyGroupId, walletType])
  @@map("family_wallets")
  @@schema("finance")
}

model PatientDebt {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  patientId  String   @map("patient_id") @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  debtAmount Decimal  @map("debt_amount") @db.Decimal(12, 2)
  dueDate    DateTime @map("due_date") @db.Timestamptz(6)
  status     String   @default("UNPAID") @db.VarChar(40) // UNPAID, RESOLVED, OVERDUE
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("patient_debts")
  @@schema("finance")
}

model PayrollRule {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  employeeId         String    @map("employee_id") @db.Uuid
  payrollType        String    @map("payroll_type") @db.VarChar(40) // REVENUE_SHARE, FIXED, HYBRID, KPI_BASED
  percentageRate     Decimal   @default(0.0) @map("percentage_rate") @db.Decimal(5, 2)
  fixedAmount        Decimal   @default(0.0) @map("fixed_amount") @db.Decimal(12, 2)
  deductMaterialCost Boolean   @default(true) @map("deduct_material_cost")
  appliesFrom        DateTime  @map("applies_from") @db.Date
  appliesTo          DateTime? @map("applies_to") @db.Date
  isActive           Boolean   @default(true) @map("is_active")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("payroll_rules")
  @@schema("finance")
}

model PayrollCalculation {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  employeeId        String   @map("employee_id") @db.Uuid
  invoiceItemId     String   @map("invoice_item_id") @db.Uuid
  sourceInvoiceId   String?  @map("source_invoice_id") @db.Uuid
  grossAmount       Decimal  @map("gross_amount") @db.Decimal(12, 2)
  materialCost      Decimal  @map("material_cost") @db.Decimal(12, 2)
  netRevenue        Decimal  @map("net_revenue") @db.Decimal(12, 2)
  payrollAmount     Decimal  @map("payroll_amount") @db.Decimal(12, 2)
  payrollPeriod     String   @map("payroll_period") @db.VarChar(40) // YYYY-MM
  calculationStatus String   @default("PENDING") @map("calculation_status") @db.VarChar(40) // PENDING, LOCKED, PAID
  calculatedBy      String   @map("calculated_by") @db.Uuid
  calculatedAt      DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  invoiceItem    InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  sourceInvoice  Invoice?    @relation(fields: [sourceInvoiceId], references: [id], onDelete: SetNull)
  calculatorUser User        @relation(fields: [calculatedBy], references: [id], onDelete: Cascade)

  @@map("payroll_calculations")
  @@schema("finance")
}

model CashierShift {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  cashierUserId     String    @map("cashier_user_id") @db.Uuid
  branchId          String    @map("branch_id") @db.Uuid
  openedAt          DateTime  @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt          DateTime? @map("closed_at") @db.Timestamptz(6)
  openingBalance    Decimal   @map("opening_balance") @db.Decimal(12, 2)
  closingBalance    Decimal?  @map("closing_balance") @db.Decimal(12, 2)
  discrepancyAmount Decimal?  @map("discrepancy_amount") @db.Decimal(12, 2)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashier User   @relation(fields: [cashierUserId], references: [id], onDelete: Cascade)
  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("cashier_shifts")
  @@schema("finance")
}
