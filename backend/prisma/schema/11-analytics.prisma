model ScheduledReport {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  reportName     String   @map("report_name") @db.VarChar(255)
  reportType     String   @map("report_type") @db.VarChar(80)
  exportFormat   String   @map("export_format") @db.VarChar(40)
  recipientsJson Json     @map("recipients_json")
  cronExpression String   @map("cron_expression") @db.VarChar(80)
  filtersJson    Json     @map("filters_json")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports GeneratedReport[]

  @@map("scheduled_reports")
  @@schema("analytics")
}

model GeneratedReport {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  scheduledReportId String?   @map("scheduled_report_id") @db.Uuid
  fileId            String?   @map("file_id") @db.Uuid
  generationStatus  String    @map("generation_status") @db.VarChar(40)
  generatedAt       DateTime  @default(now()) @map("generated_at") @db.Timestamptz(6)
  deliveredAt       DateTime? @map("delivered_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduledReport ScheduledReport? @relation(fields: [scheduledReportId], references: [id], onDelete: SetNull)

  @@map("generated_reports")
  @@schema("analytics")
}

model RealtimeMetricCache {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  metricCode  String   @map("metric_code") @db.VarChar(80)
  metricValue String   @map("metric_value") @db.VarChar(255)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricCode])
  @@map("realtime_metrics_cache")
  @@schema("analytics")
}
