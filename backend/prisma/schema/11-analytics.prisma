  measuredAt          DateTime @default(now()) @map("measured_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("retention_metrics")
  @@schema("analytics")
}

model DoctorKpiMetric {
